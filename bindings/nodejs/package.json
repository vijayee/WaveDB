{
  "name": "@vijayee/wavedb",
  "version": "0.7.0",
  "description": "Node.js bindings for WaveDB - Hierarchical B+Trie Database",
  "main": "lib/wavedb.js",
  "author": "Victor Morrow <victor.j.morrow@gmail.com>",
  "homepage": "https://github.com/vijayee/WaveDB#readme",
  "bugs": {
    "url": "https://github.com/vijayee/WaveDB/issues"
  },
  "scripts": {
    "build": "node-gyp rebuild",
    "test": "npm run build && mocha test/*.test.js",
    "test:valgrind": "valgrind --leak-check=full node test/*.test.js",
    "prepublishOnly": "ASAN_OPTIONS=detect_leaks=0 LSAN_OPTIONS=suppress_leaks=1 npm run build && ASAN_OPTIONS=detect_leaks=0 LSAN_OPTIONS=suppress_leaks=1 npm test"
  },
  "dependencies": {
    "node-addon-api": "^7.1.1",
    "node-pre-gyp": "^0.17.0"
  },
  "devDependencies": {
    "mocha": "^10.0.0",
    "node-gyp": "^9.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "license": "MIT",
  "keywords": [
    "database",
    "key-value",
    "hierarchical",
    "trie",
    "btree",
    "mvcc",
    "embedded-database",
    "storage-engine"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vijayee/WaveDB.git",
    "directory": "bindings/nodejs"
  },
  "files": [
    "lib/",
    "src/",
    "binding.gyp",
    "README.md",
    "LICENSE"
  ]
}
